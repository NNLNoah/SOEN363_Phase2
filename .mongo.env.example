# Copy to .mongo.env before starting docker compose.

# MongoDB admin account
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGEME_MONGO_ROOT_PASSWORD

# Mongo Express -> MongoDB auth (so mongo-express can connect to MongoDB)
ME_CONFIG_MONGODB_ADMINUSERNAME=admin
ME_CONFIG_MONGODB_ADMINPASSWORD=CHANGEME_MONGO_ROOT_PASSWORD

# Mongo Express basic auth (web UI login)
ME_CONFIG_BASICAUTH=true
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=CHANGEME_MONGO_EXPRESS_PASSWORD
