# Supabase Postgres source
SUPABASE_DB_HOST=aws-0-us-west-2.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your_project_ref
SUPABASE_DB_PASSWORD=PUT_YOUR_PASSWORD_HERE

# Optional URL alternative (if set, can be used instead of fields above)
# DATABASE_URL=postgresql://postgres.your_project_ref:replace-with-real-password@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# MongoDB destination
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=supabase_mirror
